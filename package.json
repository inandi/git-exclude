{
  "name": "git-exclude",
  "displayName": "Git Exclude",
  "description": "Add files and folders to your local .git/info/exclude with a single right-click.",
  "version": "1.1.1",
  "publisher": "iNandi",
  "icon": "media/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/inandi/git-exclude.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:gitExclude.addToExclude"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitExclude.addToExclude",
        "title": "$(diff-ignored) Add to .git/exclude",
        "category": "Git Exclude"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "gitExclude.addToExclude",
          "group": "7_modification@100",
          "when": "explorerResourceIsFolder || resourceScheme == file"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "20.x",
    "typescript": "^5.3.0"
  }
}
